{
  "name": "mosaic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "dev:hunt-service": "node --import tsx scripts/dev-hunt-service.ts",
    "validate-data": "node --import tsx scripts/validate-map-coordinates.ts public/data/maps/*/entries.json",
    "test": "npm run typecheck && npm run validate-data && npm run test:hunt-queue && npm run test:hunt-journey && npm run test:smoke",
    "test:smoke": "playwright test --project=mobile-light --project=mobile-dark --project=desktop-light --grep @smoke",
    "test:hunt-queue": "node --import tsx scripts/verify-hunt-queue-contract.ts",
    "test:hunt-journey": "node --import tsx scripts/verify-hunt-journey.ts",
    "test:regression": "tsx tests/verify-design-regression.ts && tsx tests/regression-full.ts",
    "test:agentic": "playwright test --grep @agentic --project=agentic-review-mobile-light --project=agentic-review-mobile-dark --project=agentic-review-tablet-light --project=agentic-review-desktop-light --project=agentic-review-desktop-dark && tsx tests/agentic-review/build-report.ts",
    "test:agentic:live": "MOSAIC_REVIEW_BASE_URL=http://gitbrain.com/mosaic/v3/ MOSAIC_SKIP_WEBSERVER=1 playwright test --grep @agentic --project=agentic-review-mobile-light --project=agentic-review-mobile-dark --project=agentic-review-tablet-light --project=agentic-review-desktop-light --project=agentic-review-desktop-dark && tsx tests/agentic-review/build-report.ts",
    "test:agentic:report": "tsx tests/agentic-review/build-report.ts",
    "benchmark:google-maps": "tsx tests/agentic-review/google-maps-benchmark.ts",
    "test:ui": "playwright test --ui",
    "research": "tsx scripts/research-agent.ts",
    "rich-research": "tsx scripts/rich-research.ts",
    "ingest-research": "tsx scripts/ingest-research.ts",
    "prepare-photos": "tsx scripts/prepare-photos.ts",
    "scrape": "tsx scripts/scrapers/run-scraper.ts",
    "aggregate-runs": "tsx scripts/aggregate-research-runs.ts",
    "enrichment-backlog": "tsx scripts/generate-enrichment-backlog.ts",
    "import-enriched-index": "tsx scripts/import-enriched-index.ts",
    "audit:map": "tsx scripts/audit-map-quality.ts",
    "enrichment:prompt": "tsx scripts/enrich-candidates.ts",
    "enrichment:run": "tsx scripts/run-enrichment-prompt.ts",
    "enrichment:verify": "tsx scripts/verify-enrichment-sources.ts",
    "enrichment:promote": "tsx scripts/promote-enrichment-artifact.ts",
    "enrichment:benchmark": "tsx scripts/benchmark-enrichment-models.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/sortablejs": "^1.15.9",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@netlify/async-workloads": "^0.0.106",
    "@netlify/blobs": "^10.7.9",
    "@tailwindcss/vite": "^4.3.0",
    "maplibre-gl": "^5.24.0",
    "sortablejs": "^1.15.7",
    "tailwindcss": "^4.3.0"
  }
}
